#!/bin/bash
#
# BIDSHub CLI - Unified command-line interface
# Usage: ./hub <command> [options]
#

set -e

# Resolve symlinks to get actual script location
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
    SCRIPT=$(readlink "$SCRIPT")
done

# Change to project root directory (parent of bin/)
cd "$(dirname "$SCRIPT")/.."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Configuration
APP_NAME="BIDSHub"
VENV_DIR="venv"
LOG_DIR="logs"
PID_FILE=".explorer.pid"
PORT_FILE=".explorer.port"

# Helper functions
print_header() {
    echo -e "${BLUE}════════════════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  $1${NC}"
    echo -e "${BLUE}════════════════════════════════════════════════════════${NC}"
}

print_success() {
    echo -e "${GREEN}[OK]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_info() {
    echo -e "${CYAN}[INFO]${NC} $1"
}

# Command: install
cmd_install() {
    print_header "Installing $APP_NAME"
    echo ""
    
    # Check Python (3.10+ required — see pyproject.toml)
    if ! command -v python3 &> /dev/null; then
        print_error "Python 3 not found"
        print_info "Install Python 3.10+ (macOS: 'brew install python@3.12') and re-run './hub install'"
        exit 1
    fi
    if ! python3 -c 'import sys; sys.exit(0 if sys.version_info >= (3, 10) else 1)'; then
        print_error "Python 3.10+ required, found $(python3 --version 2>&1)"
        print_info "Install a newer Python (macOS: 'brew install python@3.12') and re-run './hub install'"
        exit 1
    fi
    print_success "Python found: $(python3 --version)"
    
    # Create virtual environment
    if [ ! -d "$VENV_DIR" ]; then
        print_info "Creating virtual environment..."
        python3 -m venv $VENV_DIR
        print_success "Virtual environment created"
    else
        print_warning "Virtual environment already exists"
    fi
    
    # Activate virtual environment
    source $VENV_DIR/bin/activate
    
    # Upgrade pip (use `python -m pip` — robust against long venv paths / stale pip shebang)
    print_info "Upgrading pip..."
    python -m pip install --upgrade pip --quiet
    print_success "pip upgraded"

    # Install dependencies (fully pinned; see requirements.in for top-level deps)
    print_info "Installing dependencies (first run downloads ~hundreds of MB; this can take a few minutes)..."
    python -m pip install -r requirements.txt --quiet
    print_success "Dependencies installed"
    
    # One-time .env from template (never overwrite: user may already have secrets)
    if [ -f ".env" ]; then
        print_info "Using existing .env (not modified)"
    elif [ -f ".env.example" ]; then
        print_info "Creating .env from .env.example (optional: add API keys and paths)..."
        cp .env.example .env
        chmod 600 .env 2>/dev/null || true
        print_success "Created .env — edit for Pennsieve/cloud paths or set them in the app later"
    else
        print_warning ".env.example not found; create .env yourself if the app needs custom paths or API keys"
    fi
    
    # Initialize database (keep existing DB when re-running install)
    print_info "Initializing database..."
    BIDSHUB_NONINTERACTIVE=1 python scripts/init_db.py
    print_success "Database initialized"
    
    # Create logs directory
    mkdir -p $LOG_DIR
    
    echo ""
    print_success "Installation complete!"
    print_info "Run './hub start' to launch the application"
}

# Helper: Find an available port from BIDSHUB_DEFAULT_PORT (default 8501) through that + 50 inclusive.
find_available_port() {
    local d="${BIDSHUB_DEFAULT_PORT:-8501}"
    local max=$((d + 50))
    local port
    for port in $(seq "$d" "$max"); do
        if ! lsof -i:"$port" > /dev/null 2>&1; then
            echo "$port"
            return 0
        fi
    done
    echo ""
    return 1
}

# Command: start
cmd_start() {
    print_header "Starting $APP_NAME"
    echo ""
    
    # Check if already running
    if [ -f "$PID_FILE" ]; then
        PID=$(cat $PID_FILE)
        if ps -p $PID > /dev/null 2>&1; then
            PORT=$(cat $PORT_FILE 2>/dev/null || echo "unknown")
            print_warning "Already running (PID: $PID, Port: $PORT)"
            print_info "URL: http://localhost:$PORT"
            exit 0
        else
            # Stale PID file
            rm -f $PID_FILE $PORT_FILE
        fi
    fi
    
    # Check virtual environment
    if [ ! -d "$VENV_DIR" ]; then
        print_error "Virtual environment not found"
        print_info "Run './hub install' first"
        exit 1
    fi
    
    # Activate virtual environment
    source $VENV_DIR/bin/activate
    
    # Find available port
    print_info "Finding available port..."
    PORT=$(find_available_port)
    if [ -z "$PORT" ]; then
        local d="${BIDSHUB_DEFAULT_PORT:-8501}"
        print_error "No available ports in range ${d}-$((d + 50))"
        exit 1
    fi
    
    # Start application directly with streamlit
    print_info "Launching application on port $PORT..."
    python -m streamlit run app.py --server.port $PORT --server.headless true > /dev/null 2>&1 &
    
    # Get the actual Streamlit PID
    LAUNCH_PID=$!
    sleep 3
    
    # Find the actual streamlit process (child of bash)
    STREAMLIT_PID=$(pgrep -P $LAUNCH_PID 2>/dev/null || echo $LAUNCH_PID)
    
    # Save PID and port
    echo $STREAMLIT_PID > $PID_FILE
    echo $PORT > $PORT_FILE
    
    print_success "Started on port $PORT"
    print_info "PID: $STREAMLIT_PID"
    print_info "URL: http://localhost:$PORT"
    print_info "Run './hub status' to check status"
}

# Command: stop
cmd_stop() {
    print_header "Stopping $APP_NAME"
    echo ""
    
    if [ -f "$PID_FILE" ]; then
        PID=$(cat $PID_FILE)
        if ps -p $PID > /dev/null 2>&1; then
            print_info "Stopping process $PID..."
            kill $PID
            sleep 1
            
            # Force kill if still running
            if ps -p $PID > /dev/null 2>&1; then
                kill -9 $PID
            fi
            
            rm -f $PID_FILE $PORT_FILE
            print_success "Stopped"
        else
            print_warning "Not running (stale PID file)"
            rm -f $PID_FILE $PORT_FILE
        fi
    else
        # Try to find and kill streamlit processes
        PIDS=$(pgrep -f "streamlit run app.py" || echo "")
        if [ ! -z "$PIDS" ]; then
            print_info "Found running processes: $PIDS"
            kill $PIDS 2>/dev/null || true
            sleep 1
            print_success "Stopped"
        else
            print_warning "Not running"
        fi
    fi
}

# Command: restart
cmd_restart() {
    print_header "Restarting $APP_NAME"
    echo ""
    
    cmd_stop
    echo ""
    sleep 1
    cmd_start
}

# Helper: Detect Streamlit port
detect_streamlit_port() {
    local port=$(lsof -i -P -n 2>/dev/null | grep streamlit | grep LISTEN | awk '{print $9}' | cut -d: -f2 | head -1)
    echo $port
}

# Command: status
cmd_status() {
    print_header "$APP_NAME Status"
    echo ""
    
    # Check if running
    if [ -f "$PID_FILE" ]; then
        PID=$(cat $PID_FILE)
        if ps -p $PID > /dev/null 2>&1; then
            PORT=$(cat $PORT_FILE 2>/dev/null)
            
            # If port file missing, try to detect
            if [ -z "$PORT" ]; then
                PORT=$(detect_streamlit_port)
                if [ ! -z "$PORT" ]; then
                    echo $PORT > $PORT_FILE
                else
                    PORT="unknown"
                fi
            fi
            
            print_success "Running"
            echo "  PID:  $PID"
            echo "  Port: $PORT"
            echo "  URL:  http://localhost:$PORT"
            
            # Show resource usage
            CPU=$(ps -p $PID -o %cpu= 2>/dev/null | xargs || echo "N/A")
            MEM=$(ps -p $PID -o %mem= 2>/dev/null | xargs || echo "N/A")
            echo "  CPU:  ${CPU}%"
            echo "  MEM:  ${MEM}%"
        else
            print_error "Not running (stale PID file)"
            rm -f $PID_FILE $PORT_FILE
        fi
    else
        # Try to find streamlit processes
        PIDS=$(pgrep -f "streamlit run app.py" 2>/dev/null || echo "")
        if [ ! -z "$PIDS" ]; then
            print_warning "Running but no PID file found"
            echo "  PIDs: $PIDS"
            
            # Try to find port
            PORT=$(detect_streamlit_port)
            if [ ! -z "$PORT" ]; then
                echo "  Port: $PORT"
                echo "  URL:  http://localhost:$PORT"
                print_info "Run './hub stop' to clean up"
            fi
        else
            print_error "Not running"
        fi
    fi
    
    echo ""
    
    # Virtual environment status
    if [ -d "$VENV_DIR" ]; then
        print_success "Virtual environment: installed"
    else
        print_error "Virtual environment: not found"
    fi
    
    # Database status
    if [ -f "data/bidshub.db" ]; then
        DB_SIZE=$(du -h data/bidshub.db | cut -f1)
        print_success "Database: $DB_SIZE"
    else
        print_warning "Database: not initialized"
    fi
}

# Command: logs
cmd_logs() {
    print_header "$APP_NAME Logs"
    echo ""
    
    # Streamlit logs location
    STREAMLIT_LOG_DIR="$HOME/.streamlit/logs"
    
    if [ -d "$STREAMLIT_LOG_DIR" ]; then
        LATEST_LOG=$(ls -t $STREAMLIT_LOG_DIR/*.log 2>/dev/null | head -1)
        if [ ! -z "$LATEST_LOG" ]; then
            print_info "Showing logs from: $LATEST_LOG"
            print_info "Press Ctrl+C to exit"
            echo ""
            tail -f "$LATEST_LOG"
        else
            print_warning "No logs found"
        fi
    else
        print_warning "Streamlit logs directory not found"
        print_info "Start the application first: ./hub start"
    fi
}

# Command: update
cmd_update() {
    print_header "Updating $APP_NAME"
    echo ""
    
    # Check if git repo
    if [ ! -d ".git" ]; then
        print_error "Not a git repository"
        exit 1
    fi
    
    # Pull latest code
    print_info "Pulling latest code..."
    git pull origin main
    print_success "Code updated"
    
    # Activate virtual environment
    if [ -d "$VENV_DIR" ]; then
        source $VENV_DIR/bin/activate
        
        # Update dependencies
        print_info "Updating dependencies..."
        python -m pip install --upgrade -r requirements.txt --quiet
        print_success "Dependencies updated"
    else
        print_warning "Virtual environment not found"
        print_info "Run './hub install' first"
    fi
    
    echo ""
    print_success "Update complete!"
    print_info "Run './hub restart' to apply changes"
}

# Command: test
cmd_test() {
    print_header "Running Tests"
    echo ""
    
    if [ ! -d "$VENV_DIR" ]; then
        print_error "Virtual environment not found"
        exit 1
    fi
    
    source $VENV_DIR/bin/activate
    
    # Dev deps (pytest) — optional; CI installs from requirements-dev.txt
    if [ -f "requirements-dev.txt" ]; then
        print_info "Installing test dependencies..."
        pip install -q -r requirements-dev.txt
    fi
    
    print_info "Running pytest..."
    BIDSHUB_NONINTERACTIVE=1 python -m pytest tests/ -q --tb=short
    test_exit=$?
    if [ "$test_exit" -ne 0 ]; then
        print_error "Pytest failed (exit $test_exit)"
        exit "$test_exit"
    fi
    print_success "Pytest: OK"
    
    echo ""
    print_success "All tests passed!"
}

# Command: clean
cmd_clean() {
    print_header "Cleaning $APP_NAME"
    echo ""
    
    print_warning "This will remove:"
    echo "  - Virtual environment"
    echo "  - Database"
    echo "  - Logs"
    echo "  - Cache files"
    echo ""
    
    read -p "Are you sure? (y/N): " -n 1 -r
    echo ""
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Cancelled"
        exit 0
    fi
    
    # Stop if running
    cmd_stop > /dev/null 2>&1
    
    # Remove virtual environment
    if [ -d "$VENV_DIR" ]; then
        print_info "Removing virtual environment..."
        rm -rf $VENV_DIR
        print_success "Virtual environment removed"
    fi
    
    # Remove database
    if [ -f "data/bidshub.db" ]; then
        print_info "Removing database..."
        rm -f data/bidshub.db
        print_success "Database removed"
    fi
    
    # Remove logs
    if [ -d "$LOG_DIR" ]; then
        print_info "Removing logs..."
        rm -rf $LOG_DIR
        print_success "Logs removed"
    fi
    
    # Remove Python cache
    print_info "Removing cache files..."
    find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
    find . -type f -name "*.pyc" -delete 2>/dev/null || true
    rm -rf .streamlit 2>/dev/null || true
    print_success "Cache removed"
    
    # Remove PID files
    rm -f $PID_FILE $PORT_FILE
    
    echo ""
    print_success "Cleanup complete!"
    print_info "Run './hub install' to reinstall"
}

# Command: config
cmd_config() {
    print_header "$APP_NAME Configuration"
    echo ""
    
    if [ -f ".env" ]; then
        print_success "Configuration file: .env"
        echo ""
        cat .env | grep -v "^#" | grep -v "^$"
    else
        print_warning "No .env file found (run './hub install' to create from .env.example, or: cp .env.example .env)"
    fi
}

# Command: help
cmd_help() {
    print_header "$APP_NAME CLI"
    echo ""
    echo "Usage: ./hub <command> [options]"
    echo ""
    echo "Commands:"
    echo "  ${GREEN}install${NC}   Install dependencies and initialize database"
    echo "  ${GREEN}start${NC}     Start the application"
    echo "  ${GREEN}stop${NC}      Stop the application"
    echo "  ${GREEN}restart${NC}   Restart the application"
    echo "  ${GREEN}status${NC}    Check application status"
    echo "  ${GREEN}logs${NC}      View application logs (live)"
    echo "  ${GREEN}update${NC}    Pull latest code and update dependencies"
    echo "  ${GREEN}test${NC}      Run tests"
    echo "  ${GREEN}clean${NC}     Remove virtual environment and cache"
    echo "  ${GREEN}config${NC}    Show configuration"
    echo "  ${GREEN}help${NC}      Show this help message"
    echo ""
    echo "Examples:"
    echo "  ./hub install      # First time setup"
    echo "  ./hub start        # Launch the app"
    echo "  ./hub status       # Check if running"
    echo "  ./hub logs         # View logs"
    echo "  ./hub restart      # Restart the app"
    echo ""
}

# Main
main() {
    if [ $# -eq 0 ]; then
        cmd_help
        exit 0
    fi
    
    COMMAND=$1
    shift
    
    case $COMMAND in
        install)
            cmd_install "$@"
            ;;
        start)
            cmd_start "$@"
            ;;
        stop)
            cmd_stop "$@"
            ;;
        restart)
            cmd_restart "$@"
            ;;
        status)
            cmd_status "$@"
            ;;
        logs)
            cmd_logs "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        test)
            cmd_test "$@"
            ;;
        clean)
            cmd_clean "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            print_error "Unknown command: $COMMAND"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
