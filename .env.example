# BIDSHub — first `./hub install` copies this to `.env` if `.env` is missing. Edit locally; do NOT commit .env to git.
#
# Security: treat API keys like passwords. If a key is ever pushed to a repo, revoke
# and create a new key in the provider’s dashboard (e.g. Pennsieve) immediately.

# Optional: make scripts that call scripts/init_db.py non-interactive (keeps existing DB)
# BIDSHUB_NONINTERACTIVE=1
#
# Docker (compose): host port for http://localhost:<port> (container listens on 8501). If unset, ./hub-docker
# tries BIDSHUB_DEFAULT_PORT (default 8501) up to +50. Uncomment to pin:
# BIDSHUB_HOST_PORT=8501
# BIDSHUB_DEFAULT_PORT=8501
#
# Native ./hub: first free port in [BIDSHUB_DEFAULT_PORT, BIDSHUB_DEFAULT_PORT+50] (default 8501..8551)
# BIDSHUB_DEFAULT_PORT=8501

# Pennsieve Configuration (optional — you can also enter credentials in the app per dataset)
PENNSIEVE_API_KEY=your_api_key_here
PENNSIEVE_API_SECRET=your_api_secret_here

# The database lives at data/bidshub.db (created by `./hub install`). No env var needed.
